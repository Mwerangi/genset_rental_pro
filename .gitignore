# Laravel bootstrap cache (artisan optimize / config:cache / route:cache etc.)
/bootstrap/cache/*.php

# Compiled views
/storage/framework/views/*.php

# Framework cache & sessions (keep the .gitignore placeholders, ignore data files)
/storage/framework/cache/data/**
/storage/framework/sessions/**
/storage/framework/testing/**
!storage/framework/cache/.gitignore
!storage/framework/cache/data/.gitignore
!storage/framework/sessions/.gitignore
!storage/framework/testing/.gitignore
!storage/framework/.gitignore
!storage/framework/views/.gitignore

# Uploaded private files (receipts, documents etc.)
/storage/app/private/**
!storage/app/private/.gitignore

# App logs
/storage/logs/*.log

# Static HTML templates / design assets (not part of the app)
/FlexBiz/
